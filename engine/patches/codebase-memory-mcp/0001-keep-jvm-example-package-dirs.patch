diff --git a/src/discover/discover.c b/src/discover/discover.c
index 314c00c..5c0a000 100644
--- a/src/discover/discover.c
+++ b/src/discover/discover.c
@@ -131,6 +131,36 @@ static bool str_contains(const char *s, const char *sub) {
     return strstr(s, sub) != NULL;
 }
 
+static bool is_fast_skip_dir_name(const char *dirname) {
+    return str_in_list(dirname, FAST_SKIP_DIRS);
+}
+
+static bool is_jvm_source_package_path(const char *rel_path) {
+    if (!rel_path) {
+        return false;
+    }
+    return str_contains(rel_path, "/src/main/java/") ||
+           str_contains(rel_path, "/src/test/java/") ||
+           str_contains(rel_path, "/src/main/kotlin/") ||
+           str_contains(rel_path, "/src/test/kotlin/") ||
+           str_contains(rel_path, "/src/main/scala/") ||
+           str_contains(rel_path, "/src/test/scala/") ||
+           str_contains(rel_path, "/src/main/groovy/") ||
+           str_contains(rel_path, "/src/test/groovy/");
+}
+
+static bool keep_fast_source_package_dir(const char *entry_name, const char *rel_path,
+                                         cbm_index_mode_t mode) {
+    if (mode == CBM_MODE_FULL || !entry_name || !rel_path || !is_fast_skip_dir_name(entry_name)) {
+        return false;
+    }
+    if (!(strcmp(entry_name, "example") == 0 || strcmp(entry_name, "examples") == 0 ||
+          strcmp(entry_name, "sample") == 0 || strcmp(entry_name, "samples") == 0)) {
+        return false;
+    }
+    return is_jvm_source_package_path(rel_path);
+}
+
