# aka MCP server —— 追加到 ~/.codex/config.toml
# command 建议写桌面 AKA 可执行文件的绝对路径（Codex 继承的 PATH 可能比交互 shell 窄，绝对路径最稳）。
[mcp_servers.aka]
command = "/absolute/path/to/AKA"
args = ["mcp"]
# 可选项：
# startup_timeout_sec = 20            # 首次启动慢（冷启动/大注册表）时调大
# tool_timeout_sec = 60               # analyze 大仓库可能超默认时长
# default_tools_approval_mode = "auto"  # aka 工具全部只读（analyze 除外），可放心 auto
